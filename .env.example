# Copy this file to .env and fill in your Anker account credentials.
# These are the same credentials you use to log into the Anker app.

ANKER_EMAIL=you@example.com
ANKER_PASSWORD=your-anker-account-password

# Two-letter country code used at Anker account signup, e.g. DE, US, GB, FR.
ANKER_COUNTRY=DE

# Optional: minimum number of seconds between automatic background refreshes
# of cached data. Tool calls within this window reuse the cached values
# instead of hitting Anker's cloud API again. Default: 60.
ANKER_REFRESH_SECONDS=60

# Optional: default site ("system") ID to assume when a tool call omits one.
# Leave unset if you only have a single Anker Solix system.
# ANKER_SITE_ID=

# Optional: transport to run the server over. "stdio" (default) is for
# MCP hosts that launch this as a local subprocess (Claude Desktop, Claude
# Code, ...). "streamable-http" runs it as a standalone HTTP server instead -
# see the README's "Running over HTTP" section before using it.
# ANKER_MCP_TRANSPORT=stdio

# Optional: only used when ANKER_MCP_TRANSPORT is an HTTP transport.
# ANKER_MCP_HOST=127.0.0.1
# ANKER_MCP_PORT=8000
# ANKER_MCP_PATH=/mcp

# Strongly recommended when ANKER_MCP_TRANSPORT is an HTTP transport and
# ANKER_MCP_HOST is anything other than 127.0.0.1: requires every HTTP
# request to send "Authorization: Bearer <this value>", or the server
# responds 401. Generate one with e.g. `openssl rand -hex 32`.
# ANKER_MCP_AUTH_TOKEN=
